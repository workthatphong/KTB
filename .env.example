# Supabase (server-side sync)
# Example: https://your-project-ref.supabase.co
SUPABASE_URL=

# Use Service Role key for backend sync (recommended in Vercel server env)
SUPABASE_SERVICE_ROLE_KEY=

# Optional fallback alias (if your platform uses SUPABASE_KEY)
# SUPABASE_KEY=

# Optional schema (default: public)
# SUPABASE_SCHEMA=public

# Optional: override local sqlite location for development
# LOCAL_DB_PATH=data/local_dashboard.db
